{
    "name": "fight/common",
    "version": "0.1.0",
    "description": "A common library for $FIGHT projects",
    "license": "UNLICENSED",
    "require": {
        "php": ">=8.5",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Fight\\Common\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fight\\Test\\": "tests"
        }
    },
    "config": {
        "platform": {
            "php": "8.5.4",
            "ext-bcmath": "8.5.4",
            "ext-intl": "8.5.4",
            "ext-json": "8.5.4",
            "ext-pcntl": "8.5.4",
            "ext-pdo": "8.5.4",
            "ext-posix": "8.5.4",
            "ext-sockets": "8.5.4"
        },
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
